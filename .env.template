# ─────────────────────────────────────────────
# Memoo – environment variables
# Copy to .env and fill in the blanks
# ─────────────────────────────────────────────

# ── Postgres ──────────────────────────────────
POSTGRES_DB=memoo
POSTGRES_USER=memoo
POSTGRES_PASSWORD=memoo
POSTGRES_PORT=5432

# ── MinIO (S3-compatible storage) ─────────────
MINIO_ROOT_USER=memoo
MINIO_ROOT_PASSWORD=memoosecret
MINIO_BUCKET=memoo-evidence
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
# Public URL the browser uses to fetch uploaded files
MINIO_PUBLIC_URL=http://localhost:9000

# ── API (FastAPI backend) ─────────────────────
API_PORT=8000
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ── Web (Next.js frontend) ────────────────────
WEB_PORT=3000
# URL the browser uses to reach the API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# ── Gemini (Google AI) ─────────────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Used by the browser for the Gemini Live bidirectional voice session.
# Same key as GOOGLE_API_KEY — must have Gemini Live API enabled on it.
NEXT_PUBLIC_GEMINI_API_KEY=
# Optional override for Live model. Keep current unless Google deprecates it.
NEXT_PUBLIC_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# ── Adminer ───────────────────────────────────
ADMINER_PORT=8080
